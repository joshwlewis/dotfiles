# Editor
abbr -a vi nvim
abbr -a vim nvim

# Heroku
abbr -a h heroku
abbr -a hs heroku sudo

# Git
abbr -a g git

# ls (using lsd)
abbr -a ls lsd
abbr -a ll lsd -lF
abbr -a la lsd -aF
abbr -a lla lsd -laF
abbr -a lt lsd --tree

# grep with color
abbr -a grep grep --color=auto
abbr -a fgrep fgrep --color=auto
abbr -a egrep egrep --color=auto

# map
abbr -a map xargs -n1

# ripgrep with ignore file
abbr -a rg rg --ignore-file ~/.rgignore
